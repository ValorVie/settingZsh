# managed by chezmoi: settingZsh editor fragment
#
# Editor shell integrations stay isolated from 10-base so feature flags can
# toggle this file independently in a later task.

if [[ -n "${SETTINGZSH_DISABLE_EDITOR_SHELL:-}" ]]; then
  return 0
fi

# nvm lazy loading（延遲載入，加速 shell 啟動）
lazy_nvm() {
  unset -f nvm node npm npx
  export NVM_DIR="$HOME/.nvm"
  [[ -s "$NVM_DIR/nvm.sh" ]] && source "$NVM_DIR/nvm.sh"
  [[ -s "$NVM_DIR/bash_completion" ]] && source "$NVM_DIR/bash_completion"
}

if [[ -s "$HOME/.nvm/nvm.sh" ]]; then
  nvm() { lazy_nvm; nvm "$@"; }
  node() { lazy_nvm; node "$@"; }
  npm() { lazy_nvm; npm "$@"; }
  npx() { lazy_nvm; npx "$@"; }
fi
